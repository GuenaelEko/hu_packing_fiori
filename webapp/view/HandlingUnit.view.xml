<mvc:View controllerName="hupackingfiori.controller.HandlingUnits"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page id="huPage2"
        title="Handling Units"
        showNavButton="true"
        navButtonPress=".onBack">

        <subHeader>
            <Bar>
                <contentLeft>
                    <Label text="Delivery: {appModel>/deliveryNumber}" design="Bold" class="sapUiSmallMarginBegin" />
                    <Label text="— {appModel>/shipTo}" class="sapUiSmallMarginBegin" />
                </contentLeft>
                <contentRight>
                    <ObjectStatus
                        text="{= ${appModel>/handlingUnits}.length + ' HU(s)'}"
                        state="Information"
                        class="sapUiSmallMarginEnd" />
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <List id="huList2"
                items="{appModel>/handlingUnits}"
                noDataText="No handling units found for this delivery."
                growing="true"
                growingThreshold="20"
                mode="None">

                <headerToolbar>
                    <Toolbar>
                        <Title text="Handling Unit List" level="H4" />
                    </Toolbar>
                </headerToolbar>

                <items>
                    <ObjectListItem
                        title="{appModel>huNumber}"
                        intro="{appModel>material} — {appModel>description}"
                        number="{appModel>weight}"
                        numberUnit="Weight"
                        type="Inactive">

                        <attributes>
                            <ObjectAttribute title="Type" text="{appModel>type}" />
                            <ObjectAttribute title="Volume" text="{appModel>volume}" />
                            <ObjectAttribute title="Quantity" text="{appModel>quantity} pcs" />
                        </attributes>

                        <firstStatus>
                            <ObjectStatus
                                text="{appModel>status}"
                                state="{= ${appModel>status} === 'Packed' ? 'Success' : 'Warning'}" />
                        </firstStatus>

                    </ObjectListItem>
                </items>

            </List>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Back"
                    type="Default"
                    icon="sap-icon://nav-back"
                    press=".onBack" />
            </OverflowToolbar>
        </footer>

    </Page>

</mvc:View>