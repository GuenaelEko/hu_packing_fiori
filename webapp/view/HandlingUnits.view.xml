<mvc:View controllerName="hupackingfiori.controller.HandlingUnits"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page id="huPage"
        title="Handling Units"
        showNavButton="true"
        navButtonPress=".onBack">

        <subHeader>
            <Bar>
                <contentLeft>
                    <Label text="Delivery: {appModel>/deliveryNumber}" design="Bold" class="sapUiSmallMarginBegin" />
                </contentLeft>
            </Bar>
        </subHeader>

        <content>
            <List id="huList"
                items="{path: 'to_HandlingUnit'}"
                noDataText="No handling units found for this delivery."
                growing="true"
                growingThreshold="20"
                mode="SingleSelectLeft"
                busyIndicatorDelay="0"
                selectionChange=".onSelectionChange">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Handling Unit List" level="H4" />
                        <ToolbarSpacer />
                        <Button 
                            id="btnDelete"
                            text="Delete"
                            type="Negative"
                            icon="sap-icon://delete"
                            enabled="{appModel>/hasSelection}"
                            press=".onDeleteHU"
                        />
                        <Button 
                            id="btnCreate"
                            text="Create HU"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press=".onCreateHU"
                        />
                    </OverflowToolbar>
                </headerToolbar>

                <items>
                    <ObjectListItem
                        title="{ExternalHandlingUnitID}"
                        intro="Int. HU Number - {HandlingUnitNumber}"
                        number="{GrossWeight}"
                        numberUnit="{WeightUnit}"
                        type="Active"
                        press=".onHUPress">

                        <attributes>
                            <ObjectAttribute title="HU Description" text="{HandlingUnitDescription}" />
                            <ObjectAttribute title="Packaging" text="{PackagingMaterial}" />
                            <ObjectAttribute title="Volume" text="{Volume} {VolumeUnit}" />
                            <!-- <ObjectAttribute title="Quantity" text="{Quantity} {QuantityUnit}" /> -->
                        </attributes>

                        <!-- <firstStatus>
                            <ObjectStatus
                                text="{PackingStatus}"
                                state="{= ${PackingStatus} === 'C' ? 'Success' : 'Warning'}" />
                        </firstStatus> -->

                    </ObjectListItem>
                </items>

            </List>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Back"
                    type="Default"
                    icon="sap-icon://nav-back"
                    press=".onBack" />
            </OverflowToolbar>
        </footer>

    </Page>

</mvc:View>